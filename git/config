[user]
	name = Rahul
	email = 54421617+rbhar@users.noreply.github.com
[alias]
	s = status -s
	d = diff
	dc = diff --cached
	dn = diff --name-only
	c = checkout
	b = branch
	a = add
	cm = commit
	amend = commit --amend
	extend = commit --amend --no-edit
	uncommit = reset --soft HEAD~1
	cl = clone
	pl = pull
	fush = push -f
	ps = push
	rb = rebase
	cp = cherry-pick
	sh = stash
	unstage = reset HEAD --
	l = log --graph --pretty=format:'%Cred%h%Creset%x20-%C(yellow)%d%Creset%x20%s%x20%Cgreen(%cr)%x20%C(bold blue)<%an>%Creset'
	last = log -1 --stat
	ll = log --pretty=fuller
	aliases = !git config -l | grep alias | cut -c 7-
[color]
	ui = true
[core]
	editor = vim
	excludesfile = ~/dotfiles/git/ignore
	autocrlf = input
[diff]
	renames = true
	compactionHeuristic = true
	algorithm = minimal
[fetch]
	prune = true
[init]
	defaultBranch = main
[log]
	abbrevCommit = true
[push]
	default = simple
[pull]
	rebase = true
