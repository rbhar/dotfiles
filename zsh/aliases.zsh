# Clear screen
alias cl='clear'

# Docker
alias d='docker'

# Dotfiles
alias dot='cd ~/dotfiles'

# Editors
alias c='code'
alias v='vim'

# Git
alias g='git'

# Homebrew
alias brewu='brew update && brew upgrade && brew autoremove && brew cleanup --prune=all'

# List files
alias la='ls -FGall'
alias ll='ls -FGl'
alias ls='ls -FG'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Quit
alias :q='exit'

# Reload
alias reload='source ~/.zshrc'

# Tmux
alias tm='tmux'
alias tma='tmux attach -t'
alias tmk='tmux kill-session -t'
alias tml='tmux list-sessions'
alias tmn='tmux new -s'

# Yazi
alias y='yazi'
