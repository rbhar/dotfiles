alias reload='source ~/.zshrc'

alias ls='ls -G'
alias ll='ls -lGh'
alias la='ls -laGh'

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias v='vim'
alias c='code'

# Git
alias g='git'

# tmux
alias tm='tmux'
alias tml='tmux list-sessions'
alias tma='tmux attach -t'
alias tmk='tmux kill-session -a'

# Docker
alias d='docker'

# Homebrew
alias brewu='brew update && brew upgrade && brew autoremove && brew cleanup --prune=all'

# Dotfiles
alias dot='cd ~/dotfiles'

# Clear screen
alias cl='clear'

# Quit
alias :q='exit'
